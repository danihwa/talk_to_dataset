OPENAI_API_KEY=
# Supabase Postgres connection string for the read-only role.
# Use the Transaction Pooler (port 6543) from your project's Connect dialog,
# substituting the agent_readonly role and its password.
SUPABASE_DB_URL=postgresql://agent_readonly.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
